{
    "schemaVersion": 1,
    "id": "zjs",
    "name": "ZJS",
    "version": "$version",
    "description": "A framework for Minecraft that allows for live scripting and client modification using JavaScript",
    "authors": [
        "Zephy"
    ],
    "icon": "assets/zjs/logo.png",
    "license": [
        "MIT"
    ],
    "contact": {
        "sources": "https://github.com/ZLS-CT/ZJS",
        "issues": "https://github.com/ZLS-CT/ZJS/issues"
    },
    "environment": "client",
    "entrypoints": {
        "preLaunch": [
            "com.zephy.zjs.internal.launch.ZJSPreLaunch"
        ],
        "client": [
            "com.zephy.zjs.ZJS"
        ]
    },
    "mixins": [
        "zjs.mixins.json"
    ],
    "depends": {
        "minecraft": "${minecraft_version}",
        "fabricloader": ">=0.18.0",
        "fabric-api": ">=$min_fabric_api_version",
        "fabric-language-kotlin": ">=1.13.8+kotlin.2.3.0"
    }
}
